# Render Private PostgreSQL
DATABASE_URL="postgresql://user:password@your-db-hostname.render.com:5432/hrms_db?schema=public&sslmode=require"

# JWT Configuration
JWT_SECRET="your-jwt-secret-change-this-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-change-this-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Server
PORT=3000
NODE_ENV=development
